import os
import gc
import anndata as ad
import crick
import pickle
import numpy as np
from tqdm import tqdm

# Define the input and output directories
input_dir = "/lustre/scratch126/cellgen/lotfollahi/am74/Adib/TRACE/cohort/Processed/TRACE_Approach"
output_dir = "./tdigest/"
os.makedirs(output_dir, exist_ok=True)

# Iterate through each .h5ad file in the input directory
for input_file in os.listdir(input_dir):
    if input_file.endswith(".h5ad"):
        print(f"Processing file: {input_file}")
        file_path = os.path.join(input_dir, input_file)

        try:
            # Load the AnnData object
            adata = ad.read_h5ad(file_path)

            # Use var_names as input genes
            var_names = adata.var_names
            all_genes_loc = np.arange(len(var_names))

            # Initialize tdigests
            median_digests = [crick.tdigest.TDigest() for _ in range(len(var_names))]

            # Progress bar
            progress = tqdm(total=len(var_names), desc=f"Processing {input_file}")
            last_view_row = 0
            progress.update(0)

            # Iterate over each gene
            for idx, gene in enumerate(var_names):
                # Extract gene expression data for the current gene
                gene_expression = adata[:, idx].X.toarray() if hasattr(adata[:, idx].X, "toarray") else adata[:, idx].X

                # Normalize by total counts per cell and multiply by 10,000
                cell_counts = adata.obs["n_counts"].values
                normalized_data = (gene_expression.flatten() / cell_counts) * 10_000

                # If integer, convert to float
                if np.issubdtype(normalized_data.dtype, np.integer):
                    normalized_data = normalized_data.astype(np.float32)

                # Mask zeros and update the digest
                nonzero_data = np.ma.masked_equal(normalized_data, 0.0).filled(np.nan)
                median_digests[idx].update(nonzero_data)

                # Update the progress bar
                progress.update(1)

            progress.close()

            # Save the t-digests as a dictionary
            median_digest_dict = dict(zip(var_names, median_digests))
            output_file = input_file.replace(".h5ad", ".gene_median_digest_dict.pickle")
            output_path = os.path.join(output_dir, output_file)

            with open(output_path, "wb") as fp:
                pickle.dump(median_digest_dict, fp)

            print(f"Processed data saved to: {output_path}")

        except Exception as e:
            print(f"Error processing {input_file}: {e}")

        finally:
            # Ensure memory is freed after processing each file
            del adata
            gc.collect()

print("Processing complete.")
